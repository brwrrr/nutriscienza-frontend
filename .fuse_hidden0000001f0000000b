<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NutriScienza — Piano Completo · Giulia M.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --green-deep: #2D5F3F; --green-dark: #1A2E22; --green-soft: #4A8264;
      --green-tint: #E8F0EB; --cream: #F5F1E8; --cream-light: #FBF9F4;
      --gold: #C9A66B; --gold-dark: #A88349;
      --text: #2A2A2A; --text-muted: #6B6B6B; --white: #FFFFFF; --border: #E5E0D3;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      color: var(--text); line-height: 1.55;
      background: #d8d5d0;
      -webkit-font-smoothing: antialiased;
      font-size: 10.5pt;
    }
    h1, h2, h3 { font-family: 'Playfair Display', serif; font-weight: 600; letter-spacing: -0.01em; }

    /* Toolbar */
    .toolbar {
      position: sticky; top: 0; z-index: 100;
      background: var(--green-deep); color: white;
      padding: 12px 24px; text-align: center; font-size: 14px;
      display: flex; align-items: center; justify-content: center; gap: 12px;
      font-family: 'Inter', sans-serif;
    }
    .toolbar button {
      background: var(--gold); color: var(--green-dark);
      border: none; padding: 8px 18px; border-radius: 6px;
      font-weight: 600; cursor: pointer; font-family: inherit; font-size: 13px;
    }
    .toolbar button:hover { background: #B8965E; }

    /* A4 pages */
    .page {
      width: 210mm; min-height: 297mm;
      padding: 18mm 18mm 22mm;
      margin: 24px auto;
      background: white;
      box-shadow: 0 4px 24px rgba(0,0,0,0.13);
      position: relative;
      page-break-after: always;
      overflow: hidden;
    }
    .page:last-child { page-break-after: auto; }

    /* Running header */
    .page-header {
      position: absolute; top: 0; left: 0; right: 0;
      height: 14mm; padding: 6mm 18mm 0;
      border-bottom: 0.5px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 9pt;
    }
    .page-header .top-bar { position: absolute; top: 0; left: 0; right: 0; height: 4mm; background: var(--green-deep); }
    .page-header .brand { color: var(--green-deep); font-weight: 700; font-size: 10pt; }
    .page-header .brand-sub { color: var(--text-muted); font-weight: 400; margin-left: 8px; font-size: 9pt; }
    .page-header .url { color: var(--text-muted); font-size: 8.5pt; }
    .page-content { padding-top: 10mm; }

    /* Running footer */
    .page-footer {
      position: absolute; bottom: 10mm; left: 18mm; right: 18mm;
      padding-top: 4mm; border-top: 0.4px solid var(--border);
      display: flex; justify-content: space-between;
      font-size: 8pt; color: var(--text-muted);
    }

    /* ══ COVER ══ */
    .page.cover { padding: 0; }
    .cover-inner { position: relative; height: 297mm; }
    .cover-top-bar { position: absolute; top: 0; left: 0; right: 0; height: 6mm; background: var(--green-deep); }
    .cover-bg { position: absolute; top: 0; left: 0; right: 0; height: 52%; background: var(--cream); }
    .cover-content { position: relative; z-index: 1; padding: 14mm 18mm 0; }
    .cover-logo { font-family: 'Playfair Display', serif; font-size: 18pt; font-weight: 700; color: var(--green-deep); margin-bottom: 30mm; }
    .cover-logo span { color: var(--gold); }
    .cover-plan-tag {
      display: inline-block; background: var(--gold); color: white;
      padding: 2mm 6mm; border-radius: 100mm;
      font-size: 9pt; font-weight: 700; letter-spacing: 0.5px;
      text-transform: uppercase; margin-bottom: 8mm;
    }
    .cover-eyebrow { text-transform: uppercase; letter-spacing: 3px; font-size: 9pt; color: var(--gold-dark); font-weight: 700; margin-bottom: 8mm; }
    .cover-title { font-size: 42pt; line-height: 1.05; color: var(--green-deep); font-family: 'Playfair Display', serif; font-weight: 600; letter-spacing: -0.02em; }
    .cover-title .soft { color: var(--green-soft); display: block; }
    .cover-rule { width: 25mm; height: 2px; background: var(--gold); margin: 8mm 0 5mm; }
    .cover-subtitle { font-size: 10.5pt; color: var(--text-muted); max-width: 130mm; line-height: 1.6; }

    .customer-card {
      position: absolute; left: 18mm; right: 18mm; top: 170mm;
      background: white; border: 0.6px solid var(--border);
      border-radius: 4mm; padding: 10mm 12mm; z-index: 2;
      box-shadow: 0 2mm 8mm rgba(0,0,0,0.07);
    }
    .customer-card .label { font-size: 8pt; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; margin-bottom: 2mm; }
    .customer-card h2 { font-size: 22pt; color: var(--green-deep); margin-bottom: 1.5mm; }
    .customer-card .meta { font-size: 11pt; color: var(--text-muted); margin-bottom: 6mm; padding-bottom: 6mm; border-bottom: 0.4px solid var(--border); }
    .customer-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8mm; }
    .customer-grid div h4 { font-size: 8pt; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5mm; font-family: 'Inter', sans-serif; }
    .customer-grid div p { font-size: 11pt; color: var(--text); }

    .cover-authority { position: absolute; left: 0; right: 0; bottom: 16mm; text-align: center; font-size: 9pt; color: var(--text-muted); padding: 0 18mm; }
    .cover-authority p { margin-bottom: 1mm; }
    .cover-bottom-bar { position: absolute; bottom: 0; left: 0; right: 0; height: 6mm; background: var(--green-deep); }
    .cover-bottom-bar2 { position: absolute; bottom: 6mm; left: 0; right: 0; height: 1.5mm; background: var(--gold); }

    /* ══ Typography ══ */
    .eyebrow { text-transform: uppercase; letter-spacing: 2px; font-size: 8.5pt; color: var(--gold-dark); font-weight: 700; margin-bottom: 4mm; }
    h1.section { font-size: 26pt; color: var(--green-deep); margin-bottom: 5mm; line-height: 1.15; }
    h2.section { font-size: 14pt; color: var(--green-deep); margin: 7mm 0 3mm; }
    h3.section { font-size: 11pt; color: var(--green-deep); margin: 4mm 0 2mm; font-family: 'Playfair Display', serif; }
    .lead { font-size: 11pt; color: var(--text-muted); margin-bottom: 6mm; line-height: 1.6; }
    p.justify { text-align: justify; font-size: 10pt; margin-bottom: 3.5mm; }

    /* Profile table */
    table.data { width: 100%; border-collapse: collapse; margin-bottom: 7mm; background: var(--cream-light); }
    table.data td { padding: 3mm 4mm; border: 0.4px solid var(--border); font-size: 10pt; }
    table.data td.label { font-weight: 700; width: 22%; background: var(--cream); }

    /* Metric cards */
    .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4mm; margin-bottom: 6mm; }
    .metric { background: var(--cream-light); border: 0.5px solid var(--border); border-radius: 3mm; padding: 5mm 5mm; }
    .metric .ml { font-size: 7.5pt; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5mm; }
    .metric .mv { font-size: 17pt; color: var(--green-deep); font-weight: 700; font-family: 'Playfair Display', serif; line-height: 1; margin-bottom: 1mm; }
    .metric .ms { font-size: 8.5pt; color: var(--text-muted); }

    .metrics3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4mm; margin-bottom: 6mm; }

    /* Macro bar */
    .macro-bar-wrap { margin-bottom: 6mm; }
    .macro-bar-row { display: flex; align-items: center; gap: 4mm; margin-bottom: 2.5mm; font-size: 9.5pt; }
    .macro-bar-label { width: 28mm; font-weight: 600; }
    .macro-bar-track { flex: 1; height: 5mm; background: var(--border); border-radius: 1mm; overflow: hidden; }
    .macro-bar-fill { height: 100%; border-radius: 1mm; }
    .macro-bar-val { width: 22mm; text-align: right; color: var(--text-muted); }

    /* Callout */
    .callout { background: var(--green-tint); border-left: 1mm solid var(--green-deep); padding: 4mm 6mm; border-radius: 0 2mm 2mm 0; margin: 4mm 0; }
    .callout.gold { background: var(--cream); border-left-color: var(--gold); }
    .callout h4 { font-size: 10.5pt; color: var(--green-deep); margin-bottom: 1.5mm; font-family: 'Inter', sans-serif; font-weight: 700; }
    .callout.gold h4 { color: var(--gold-dark); }
    .callout p, .callout li { font-size: 9.5pt; margin: 0; line-height: 1.6; }
    .callout ul { padding-left: 5mm; margin-top: 2mm; }

    /* Week tabs */
    .week-label {
      display: inline-block; background: var(--green-deep); color: white;
      padding: 2mm 6mm; border-radius: 100mm;
      font-size: 9pt; font-weight: 700; letter-spacing: 0.5px;
      margin-bottom: 5mm; text-transform: uppercase;
    }
    .week-label.w2 { background: var(--green-soft); }
    .week-label.w3 { background: var(--gold-dark); }
    .week-label.w4 { background: #5C8B72; }

    /* Day meal block */
    .day { margin-bottom: 5.5mm; page-break-inside: avoid; }
    .day-header {
      background: var(--green-deep); color: white;
      padding: 2.5mm 5mm; font-weight: 700; font-size: 10.5pt;
      border-radius: 2mm 2mm 0 0;
      display: flex; justify-content: space-between; align-items: center;
    }
    .day-header span:last-child { font-size: 8.5pt; font-weight: 500; opacity: 0.88; }
    .day-header.alt { background: var(--green-soft); }
    .day-header.weekend { background: var(--gold-dark); }
    table.meals {
      width: 100%; border-collapse: collapse;
      border: 0.5px solid var(--border); border-top: none;
      font-size: 9.5pt;
    }
    table.meals td { padding: 2.5mm 4mm; vertical-align: top; border-bottom: 0.3px solid var(--border); }
    table.meals tr:last-child td { border-bottom: none; }
    table.meals td.meal-name { width: 20%; font-weight: 700; color: var(--green-deep); }
    table.meals td.food { width: 50%; }
    table.meals td.qty { width: 16%; color: var(--text-muted); font-size: 9pt; }
    table.meals td.kcal { width: 14%; text-align: right; color: var(--text-muted); font-size: 9pt; white-space: nowrap; }
    table.meals td.kcal strong { color: var(--green-deep); font-family: 'Playfair Display', serif; font-size: 11pt; }
    table.meals tr.day-total td { background: var(--cream-light); font-weight: 700; font-size: 9pt; border-top: 0.5px solid var(--border); }

    /* Two-column day layout */
    .days-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5mm; }

    /* Workout */
    .workout-day { margin-bottom: 7mm; page-break-inside: avoid; }
    .workout-header {
      background: var(--green-deep); color: white;
      padding: 3mm 5mm; border-radius: 2mm 2mm 0 0;
      display: flex; justify-content: space-between;
    }
    .workout-header h3 { color: white; font-size: 11pt; margin: 0; font-family: 'Playfair Display', serif; }
    .workout-header span { font-size: 9pt; opacity: 0.85; font-family: 'Inter', sans-serif; align-self: center; }
    table.exercises {
      width: 100%; border-collapse: collapse;
      border: 0.5px solid var(--border); border-top: none; font-size: 9.5pt;
    }
    table.exercises th { background: var(--cream); padding: 2.5mm 4mm; text-align: left; font-size: 8.5pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); border-bottom: 0.5px solid var(--border); }
    table.exercises td { padding: 2.5mm 4mm; border-bottom: 0.3px solid var(--border); vertical-align: middle; }
    table.exercises tr:last-child td { border-bottom: none; }
    table.exercises td.ex-name { font-weight: 600; }
    table.exercises td.ex-sets { text-align: center; color: var(--green-deep); font-weight: 700; }
    table.exercises td.ex-reps { text-align: center; }
    table.exercises td.ex-rest { text-align: center; color: var(--text-muted); font-size: 9pt; }
    table.exercises td.ex-note { font-size: 9pt; color: var(--text-muted); font-style: italic; }
    .ex-group { padding: 2mm 4mm; background: var(--green-tint); font-weight: 700; font-size: 8.5pt; text-transform: uppercase; letter-spacing: 1px; color: var(--green-deep); border-bottom: 0.3px solid var(--border); }

    /* Shopping list */
    .shop-col { column-count: 3; column-gap: 6mm; margin-bottom: 5mm; }
    .shop-cat { break-inside: avoid; margin-bottom: 4mm; }
    .shop-cat h4 { font-size: 9.5pt; font-weight: 700; color: var(--green-deep); margin-bottom: 2mm; padding-bottom: 1mm; border-bottom: 0.5px solid var(--border); font-family: 'Inter', sans-serif; text-transform: uppercase; letter-spacing: 0.8px; }
    .shop-cat ul { list-style: none; }
    .shop-cat li { font-size: 9pt; padding: 0.8mm 0 0.8mm 4mm; position: relative; line-height: 1.45; border-bottom: 0.3px solid var(--border); color: var(--text); }
    .shop-cat li:last-child { border-bottom: none; }
    .shop-cat li::before { content: "□"; position: absolute; left: 0; color: var(--green-deep); font-size: 8pt; }
    .shop-cat li span { color: var(--text-muted); font-size: 8.5pt; }

    /* Tip boxes */
    .tip-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5mm; margin-bottom: 5mm; }
    .tip-box { background: var(--cream-light); border: 0.5px solid var(--border); border-radius: 2mm; padding: 5mm 6mm; }
    .tip-box h4 { font-size: 10pt; color: var(--green-deep); margin-bottom: 2mm; font-family: 'Playfair Display', serif; }
    .tip-box p, .tip-box li { font-size: 9pt; color: var(--text); line-height: 1.6; }
    .tip-box ul { padding-left: 5mm; margin-top: 2mm; }

    /* Disclaimer */
    .disclaimer { background: var(--cream); border-left: 1mm solid var(--gold); padding: 5mm 7mm; margin: 6mm 0; font-size: 9pt; line-height: 1.55; }
    .disclaimer h4 { font-family: 'Inter', sans-serif; font-weight: 700; color: var(--gold-dark); font-size: 9.5pt; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 2.5mm; }

    /* Signature */
    .signature { display: grid; grid-template-columns: 1fr 1fr; gap: 8mm; padding-top: 5mm; border-top: 0.5px solid var(--border); margin-top: 6mm; font-size: 9.5pt; }
    .signature strong { color: var(--green-deep); }
    .sig-line { border-bottom: 0.5px solid var(--text-muted); height: 10mm; margin-bottom: 2mm; }

    /* Progress tracker */
    .progress-table { width: 100%; border-collapse: collapse; font-size: 9.5pt; margin-bottom: 5mm; }
    .progress-table th { background: var(--green-deep); color: white; padding: 2.5mm 4mm; font-size: 8.5pt; font-weight: 600; }
    .progress-table td { padding: 4mm 4mm; border: 0.4px solid var(--border); text-align: center; }
    .progress-table td.week-col { font-weight: 700; color: var(--green-deep); background: var(--cream-light); text-align: left; }
    .progress-table td.input { background: #FAFAFA; color: var(--text-muted); font-style: italic; font-size: 9pt; }

    /* ══ PRINT ══ */
    @page { size: A4; margin: 0; }
    @media print {
      body { background: white; }
      .toolbar { display: none; }
      .page { margin: 0; box-shadow: none; page-break-after: always; width: 210mm; height: 297mm; }
      .page:last-child { page-break-after: auto; }
    }
  </style>
</head>
